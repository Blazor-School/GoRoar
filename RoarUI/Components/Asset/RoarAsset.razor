@code {
    protected override void OnInitialized()
    {
        RoarDependencyService.OnComponentsChanged += OnComponentsChangedHandler;
        ThemeService.OnThemeLoaded += OnThemeLoadedHandler;
    }

    public void OnComponentsChangedHandler(object? sender, EventArgs args)
    {
        StateHasChanged();
    }

    public void OnThemeLoadedHandler(object? sender, RoarTheme theme)
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        RoarDependencyService.OnComponentsChanged -= OnComponentsChangedHandler;
        ThemeService.OnThemeLoaded -= OnThemeLoadedHandler;
    }
}