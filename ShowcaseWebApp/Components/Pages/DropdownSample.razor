@page "/dropdown-sample"

<h3>Getting the Selected Item</h3>
<RoarDropdown @bind-Value="SelectedValue" OnSelectPreventDefault="KeepMenuOpen">
    <RoarButton Appearance="ButtonAppearance.Filled" slot="trigger" WithCaret>View</RoarButton>
    <RoarDropdownItem Value="full-screen">Enter full screen</RoarDropdownItem>
    <RoarDropdownItem Value="actual">Actual size</RoarDropdownItem>
    <RoarDropdownItem Value="zoom-in">Zoom in</RoarDropdownItem>
    <RoarDropdownItem Value="zoom-out">Zoom out</RoarDropdownItem>
</RoarDropdown>
<p>Selected value: @SelectedValue</p>
<label>
    <InputCheckbox @bind-Value="KeepMenuOpen" /> Keep menu open after selection
</label>

<h3>Showing Icons</h3>
<RoarDropdown>
    <RoarButton Appearance="ButtonAppearance.Filled" slot="trigger" WithCaret>Edit</RoarButton>
    <RoarDropdownItem Value="cut">
        <RoarIcon slot="icon" Name="scissors"></RoarIcon>
        Cut
    </RoarDropdownItem>
    <RoarDropdownItem Value="copy">
        <RoarIcon slot="icon" Name="copy"></RoarIcon>
        Copy
    </RoarDropdownItem>
    <RoarDropdownItem Value="paste">
        <RoarIcon slot="icon" Name="paste"></RoarIcon>
        Paste
    </RoarDropdownItem>
    <RoarDropdownItem Value="delete" Variant="DropdownItemVariant.Danger">
        <RoarIcon slot="icon" Name="trash"></RoarIcon>
        Delete
    </RoarDropdownItem>
</RoarDropdown>

<h3>Showing Labels & Dividers</h3>
<RoarDropdown>
    <RoarButton Appearance="ButtonAppearance.Filled" slot="trigger" WithCaret>Device</RoarButton>
    <h3>Type</h3>
    <RoarDropdownItem Value="phone">Phone</RoarDropdownItem>
    <RoarDropdownItem Value="tablet">Tablet</RoarDropdownItem>
    <RoarDropdownItem Value="desktop">Desktop</RoarDropdownItem>
    <RoarDivider />
    <RoarDropdownItem Value="more">More options...</RoarDropdownItem>
</RoarDropdown>


<h3>Showing Details</h3>
<RoarDropdown>
    <RoarButton Appearance="ButtonAppearance.Filled" slot="trigger" WithCaret>Message</RoarButton>

    <RoarDropdownItem Value="reply">
        Reply
        <span slot="details">⌘R</span>
    </RoarDropdownItem>

    <RoarDropdownItem Value="forward">
        Forward
        <span slot="details">⌘F</span>
    </RoarDropdownItem>

    <RoarDropdownItem value="move">
        Move
        <span slot="details">⌘M</span>
    </RoarDropdownItem>

    <RoarDivider />

    <RoarDropdownItem Value="archive">
        Archive
        <span slot="details">⌘A</span>
    </RoarDropdownItem>

    <RoarDropdownItem Value="delete" Variant="DropdownItemVariant.Danger">
        Delete
        <span slot="details">Del</span>
    </RoarDropdownItem>
</RoarDropdown>

<h3>Checkable Items</h3>
<RoarDropdown CheckboxItemSelected="OnCheckboxItemSelected">
    <RoarButton Appearance="ButtonAppearance.Filled" slot="trigger" WithCaret>View</RoarButton>

    <RoarDropdownCheckboxItem Value="canvas" Checked="@CheckedItems["canvas"]">Show canvas</RoarDropdownCheckboxItem>
    <RoarDropdownCheckboxItem Value="grid" Checked="@CheckedItems["grid"]">Show grid</RoarDropdownCheckboxItem> @*Users can omit the true value*@
    <RoarDropdownCheckboxItem Value="source" Checked="@CheckedItems["source"]">Show source</RoarDropdownCheckboxItem>
    <RoarDivider />

    <RoarDropdownItem Value="preferences">Preferences...</RoarDropdownItem>
</RoarDropdown>

<div>
    @foreach (var pair in CheckedItems)
    {
        <p>@pair.Key: @pair.Value</p>
    }
</div>

<h3>Destructive Items</h3>
<RoarDropdown>
    <RoarButton Appearance="ButtonAppearance.Filled" slot="trigger" WithCaret>Project</RoarButton>

    <RoarDropdownItem Value="share">
        <RoarIcon slot="icon" Name="share"></RoarIcon>
        Share
    </RoarDropdownItem>
    <RoarDropdownItem Value="preferences">
        <RoarIcon slot="icon" Name="gear"></RoarIcon>
        Preferences
    </RoarDropdownItem>
    <RoarDivider />
    <h3>Danger zone</h3>
    <RoarDropdownItem Value="archive">
        <RoarIcon slot="icon" Name="archive"></RoarIcon>
        Archive
    </RoarDropdownItem>
    <RoarDropdownItem Value="danger" Variant="DropdownItemVariant.Danger">
        <RoarIcon slot="icon" Name="trash"></RoarIcon>
        Delete
    </RoarDropdownItem>
</RoarDropdown>

<h3>Placement</h3>
<RoarDropdown Placement="DropdownPlacement.RightStart">
    <RoarButton Appearance="ButtonAppearance.Filled" slot="trigger">
        File formats
        <RoarIcon slot="end" Name="chevron-right"></RoarIcon>
    </RoarButton>

    <RoarDropdownItem Value="pdf">PDF Document</RoarDropdownItem>
    <RoarDropdownItem Value="docx">Word Document</RoarDropdownItem>
    <RoarDropdownItem Value="xlsx">Excel Spreadsheet</RoarDropdownItem>
    <RoarDropdownItem Value="pptx">PowerPoint Presentation</RoarDropdownItem>
    <RoarDropdownItem Value="txt">Plain Text</RoarDropdownItem>
    <RoarDropdownItem Value="json">JSON File</RoarDropdownItem>
</RoarDropdown>

<h3>Distance</h3>
<RoarDropdown Distance="30">
    <RoarButton Appearance="ButtonAppearance.Filled" slot="trigger" WithCaret>Edit</RoarButton>

    <RoarDropdownItem>Cut</RoarDropdownItem>
    <RoarDropdownItem>Copy</RoarDropdownItem>
    <RoarDropdownItem>Paste</RoarDropdownItem>
    <RoarDivider />
    <RoarDropdownItem>Find</RoarDropdownItem>
    <RoarDropdownItem>Replace</RoarDropdownItem>
</RoarDropdown>

<h3>Offset</h3>
<RoarDropdown Skidding="30">
    <RoarButton Appearance="ButtonAppearance.Filled" slot="trigger" WithCaret>Edit</RoarButton>

    <RoarDropdownItem>Cut</RoarDropdownItem>
    <RoarDropdownItem>Copy</RoarDropdownItem>
    <RoarDropdownItem>Paste</RoarDropdownItem>
    <RoarDivider />
    <RoarDropdownItem>Find</RoarDropdownItem>
    <RoarDropdownItem>Replace</RoarDropdownItem>
</RoarDropdown>

<h3>Submenus</h3>
<RoarDropdown ValueChanged="OnSubmenuSelected" CheckboxItemSelected="OnSubmenuCheckboxItemSelected">
    <RoarButton Appearance="ButtonAppearance.Filled" slot="trigger" WithCaret>Export</RoarButton>

    <RoarDropdownItem>
        Documents
        <RoarDropdownItem slot="submenu" Value="pdf">PDF</RoarDropdownItem>
        <RoarDropdownItem slot="submenu" Value="docx">Word Document</RoarDropdownItem>
    </RoarDropdownItem>

    <RoarDropdownItem>
        Spreadsheets
        <RoarDropdownItem slot="submenu">
            Excel Formats
            <RoarDropdownItem slot="submenu" Value="xlsx">Excel (.xlsx)</RoarDropdownItem>
            <RoarDropdownItem slot="submenu" Value="xls">Excel 97-2003 (.xls)</RoarDropdownItem>
            <RoarDropdownItem slot="submenu" Value="csv">CSV (.csv)</RoarDropdownItem>
        </RoarDropdownItem>

        <RoarDropdownItem slot="submenu">
            Other Formats
            <RoarDropdownItem slot="submenu" Value="ods">OpenDocument (.ods)</RoarDropdownItem>
            <RoarDropdownItem slot="submenu" Value="tsv">Tab-separated (.tsv)</RoarDropdownItem>
            <RoarDropdownItem slot="submenu" Value="json">JSON (.json)</RoarDropdownItem>
        </RoarDropdownItem>

        <RoarDropdownItem slot="submenu" Value="numbers">Apple Numbers</RoarDropdownItem>
    </RoarDropdownItem>

    <RoarDivider />

    <RoarDropdownItem>
        Options
        <RoarDropdownCheckboxItem slot="submenu" Value="compress" Checked="@CheckedItemsSubmenu["compress"]">Compress files</RoarDropdownCheckboxItem>
        <RoarDropdownCheckboxItem slot="submenu" Value="metadata" Checked="@CheckedItemsSubmenu["metadata"]">Include metadata</RoarDropdownCheckboxItem>
        <RoarDropdownCheckboxItem slot="submenu" Value="password" Checked="@CheckedItemsSubmenu["password"]">Password protect</RoarDropdownCheckboxItem>
    </RoarDropdownItem>
</RoarDropdown>
<p>Selected submenu: @SelectedSubmenu</p>
<div>
    @foreach (var pair in CheckedItemsSubmenu)
    {
        <p>@pair.Key: @pair.Value</p>
    }
</div>

<h3>Disabling Items</h3>
<RoarDropdown>
    <RoarButton Appearance="ButtonAppearance.Filled" slot="trigger" WithCaret>Payment method</RoarButton>

    <RoarDropdownItem Value="cash">Cash</RoarDropdownItem>
    <RoarDropdownItem Value="check" Disabled="true">Personal check</RoarDropdownItem>
    <RoarDropdownItem Value="credit">Credit card</RoarDropdownItem>
    <RoarDropdownItem Value="gift-card">Gift card</RoarDropdownItem>
</RoarDropdown>

@code {
    public bool KeepMenuOpen { get; set; }
    public string SelectedValue { get; set; } = "";
    public string SelectedSubmenu { get; set; } = "";

    public Dictionary<string, bool> CheckedItems { get; set; } = new()
    {
        ["canvas"] = true,
        ["grid"] = true,
        ["source"] = false
    };

    public Dictionary<string, bool> CheckedItemsSubmenu { get; set; } = new()
    {
        ["compress"] = false,
        ["metadata"] = true,
        ["password"] = false
    };

    public void OnCheckboxItemSelected(KeyValuePair<string, bool> recentCheckboxItem)
    {
        CheckedItems[recentCheckboxItem.Key] = recentCheckboxItem.Value;
    }

    public void OnSubmenuSelected(string selectedSubmenu)
    {
        SelectedSubmenu = selectedSubmenu;
    }

    public void OnSubmenuCheckboxItemSelected(KeyValuePair<string, bool> recentCheckboxItem)
    {
        CheckedItemsSubmenu[recentCheckboxItem.Key] = recentCheckboxItem.Value;
    }
}
