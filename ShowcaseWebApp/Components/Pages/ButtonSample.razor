@page "/button-sample"

<h3>Basic</h3>
<RoarButton @onclick="SayHello">Click me!</RoarButton>

<h3>Variants</h3>
<RoarButton>Default</RoarButton>
<RoarButton Variant="Variant.Neutral">Neutral</RoarButton>
<RoarButton Variant="Variant.Brand">Brand</RoarButton>
<RoarButton Variant="Variant.Success">Success</RoarButton>
<RoarButton Variant="Variant.Warning">Warning</RoarButton>
<RoarButton Variant="Variant.Danger">Danger</RoarButton>

<h3>Appearance</h3>
<div class="wa-stack wa-gap-xs">
    <div>
        <RoarButton Variant="Variant.Neutral" Appearance="ButtonAppearance.Accent">Accent</RoarButton>
        <RoarButton Variant="Variant.Neutral" Appearance="ButtonAppearance.FilledOutline">Filled-Outline</RoarButton>
        <RoarButton Variant="Variant.Neutral" Appearance="ButtonAppearance.Filled">Filled</RoarButton>
        <RoarButton Variant="Variant.Neutral" Appearance="ButtonAppearance.Outlined">Outlined</RoarButton>
        <RoarButton Variant="Variant.Neutral" Appearance="ButtonAppearance.Plain">Plain</RoarButton>
    </div>

    <div>
        <RoarButton Variant="Variant.Brand" Appearance="ButtonAppearance.Accent">Accent</RoarButton>
        <RoarButton Variant="Variant.Brand" Appearance="ButtonAppearance.FilledOutline">Filled-Outline</RoarButton>
        <RoarButton Variant="Variant.Brand" Appearance="ButtonAppearance.Filled">Filled</RoarButton>
        <RoarButton Variant="Variant.Brand" Appearance="ButtonAppearance.Outlined">Outlined</RoarButton>
        <RoarButton Variant="Variant.Brand" Appearance="ButtonAppearance.Plain">Plain</RoarButton>
    </div>

    <div>
        <RoarButton Variant="Variant.Success" Appearance="ButtonAppearance.Accent">Accent</RoarButton>
        <RoarButton Variant="Variant.Success" Appearance="ButtonAppearance.FilledOutline">Filled-Outline</RoarButton>
        <RoarButton Variant="Variant.Success" Appearance="ButtonAppearance.Filled">Filled</RoarButton>
        <RoarButton Variant="Variant.Success" Appearance="ButtonAppearance.Outlined">Outlined</RoarButton>
        <RoarButton Variant="Variant.Success" Appearance="ButtonAppearance.Plain">Plain</RoarButton>
    </div>

    <div>
        <RoarButton Variant="Variant.Warning" Appearance="ButtonAppearance.Accent">Accent</RoarButton>
        <RoarButton Variant="Variant.Warning" Appearance="ButtonAppearance.FilledOutline">Filled-Outline</RoarButton>
        <RoarButton Variant="Variant.Warning" Appearance="ButtonAppearance.Filled">Filled</RoarButton>
        <RoarButton Variant="Variant.Warning" Appearance="ButtonAppearance.Outlined">Outlined</RoarButton>
        <RoarButton Variant="Variant.Warning" Appearance="ButtonAppearance.Plain">Plain</RoarButton>
    </div>

    <div>
        <RoarButton Variant="Variant.Danger" Appearance="ButtonAppearance.Accent">Accent</RoarButton>
        <RoarButton Variant="Variant.Danger" Appearance="ButtonAppearance.FilledOutline">Filled-Outline</RoarButton>
        <RoarButton Variant="Variant.Danger" Appearance="ButtonAppearance.Filled">Filled</RoarButton>
        <RoarButton Variant="Variant.Danger" Appearance="ButtonAppearance.Outlined">Outlined</RoarButton>
        <RoarButton Variant="Variant.Danger" Appearance="ButtonAppearance.Plain">Plain</RoarButton>
    </div>
</div>

<h3>Size</h3>
<RoarButton Size="ButtonSize.Small">Small</RoarButton>
<RoarButton Size="ButtonSize.Medium">Medium</RoarButton>
<RoarButton Size="ButtonSize.Large">Large</RoarButton>

<h3>Pill</h3>
<RoarButton Pill="true">Pill Button</RoarButton>
<RoarButton Pill="false">Non-pill Button</RoarButton>

<h3>Link Buttons</h3>
<RoarLinkButton Href="https://www.microsoft.com">Microsoft</RoarLinkButton>
<RoarLinkButton Href="https://www.microsoft.com" Target="LinkTarget.Blank">Microsoft (new window)</RoarLinkButton>

<h3>Icon Buttons</h3>
<div>
    <RoarButton Appearance="ButtonAppearance.Accent"><RoarIcon Name="home" /></RoarButton>
    <RoarButton Appearance="ButtonAppearance.Outlined"><RoarIcon Name="home" /></RoarButton>
    <RoarButton Appearance="ButtonAppearance.Filled"><RoarIcon Name="home" /></RoarButton>
    <RoarButton Appearance="ButtonAppearance.FilledOutline"><RoarIcon Name="home" /></RoarButton>
    <RoarButton Appearance="ButtonAppearance.Plain"><RoarIcon Name="home" /></RoarButton>
</div>
<div>
    <RoarLinkButton Href="https://www.microsoft.com" Appearance="ButtonAppearance.Accent"><RoarIcon Family="FontAwesomeFamily.Brands" Name="microsoft" /></RoarLinkButton>
    <RoarLinkButton Href="https://www.microsoft.com" Appearance="ButtonAppearance.Outlined"><RoarIcon Family="FontAwesomeFamily.Brands" Name="microsoft" /></RoarLinkButton>
    <RoarLinkButton Href="https://www.microsoft.com" Appearance="ButtonAppearance.Filled"><RoarIcon Family="FontAwesomeFamily.Brands" Name="microsoft" /></RoarLinkButton>
    <RoarLinkButton Href="https://www.microsoft.com" Appearance="ButtonAppearance.FilledOutline"><RoarIcon Family="FontAwesomeFamily.Brands" Name="microsoft" /></RoarLinkButton>
    <RoarLinkButton Href="https://www.microsoft.com" Appearance="ButtonAppearance.Plain"><RoarIcon Family="FontAwesomeFamily.Brands" Name="microsoft" /></RoarLinkButton>
</div>

<h3>Type</h3>
<RoarButton Type="ButtonType.Button">General Button</RoarButton>
<RoarButton Type="ButtonType.Submit">Submit Button</RoarButton>
<RoarButton Type="ButtonType.Reset">Reset Button</RoarButton>

<h3>Loading</h3>
<RoarButton Variant="Variant.Neutral" Loading="IsLoading" @onclick="InitiateLoadingAsync">Neutral</RoarButton>
<RoarButton Variant="Variant.Brand" Loading="IsLoading" @onclick="InitiateLoadingAsync">Brand</RoarButton>
<RoarButton Variant="Variant.Success" Loading="IsLoading" @onclick="InitiateLoadingAsync">Success</RoarButton>
<RoarButton Variant="Variant.Warning" Loading="IsLoading" @onclick="InitiateLoadingAsync">Warning</RoarButton>
<RoarButton Variant="Variant.Danger" Loading="IsLoading" @onclick="InitiateLoadingAsync">Danger</RoarButton>

<h3>Disabled</h3>
<RoarButton @onclick="ToggleDisabled">Toggle Status</RoarButton>
<RoarButton Variant="Variant.Neutral" Disabled="ButtonDisabled" @onclick="ToggleDisabled">Neutral</RoarButton>
<RoarButton Variant="Variant.Brand" Disabled="ButtonDisabled" @onclick="ToggleDisabled">Brand</RoarButton>
<RoarButton Variant="Variant.Success" Disabled="ButtonDisabled" @onclick="ToggleDisabled">Success</RoarButton>
<RoarButton Variant="Variant.Warning" Disabled="ButtonDisabled" @onclick="ToggleDisabled">Warning</RoarButton>
<RoarButton Variant="Variant.Danger" Disabled="ButtonDisabled" @onclick="ToggleDisabled">Danger</RoarButton>

<h3>Methods & Events</h3>
<div>
    <RoarButton Variant="Variant.Neutral" @ref="Button1" @onclick="SayHello" OnBlur="Button1Blured" OnFocus="Button1Focused" OnInvalid="Button1Invalid">Button1</RoarButton>

    <RoarButton Variant="Variant.Brand" @onclick="BlurButton1Async">Blur Button1</RoarButton>
    <RoarButton Variant="Variant.Brand" @onclick="ClickButton1Async">Click Button1</RoarButton>
    <RoarButton Variant="Variant.Brand" @onclick="FocusButton1Async">Focus Button1</RoarButton>
</div>

<div>
    <RoarLinkButton Href="https://google.com" Variant="Variant.Neutral" @ref="LinkButton1" OnBlur="LinkButton1Blured" OnFocus="LinkButton1Focused" OnInvalid="LinkButton1Invalid">LinkButton1</RoarLinkButton>

    <RoarButton Variant="Variant.Brand" @onclick="BlurLinkButton1Async">Blur LinkButton1</RoarButton>
    <RoarButton Variant="Variant.Brand" @onclick="FocusLinkButton1Async">Focus LinkButton1</RoarButton>
</div>

@code {
    public bool IsLoading { get; set; } = false;
    public bool ButtonDisabled { get; set; } = true;
    public RoarButton Button1 { get; set; }
    public RoarLinkButton LinkButton1 { get; set; }

    public async Task InitiateLoadingAsync()
    {
        IsLoading = true;
        await Task.Delay(TimeSpan.FromSeconds(5));
        IsLoading = false;
    }

    public void ToggleDisabled() => ButtonDisabled = !ButtonDisabled;

    public void SayHello()
    {
        Console.WriteLine("Roar!");
    }

    public async Task BlurButton1Async()
    {
        await Button1.BlurAsync();
    }

    public async Task ClickButton1Async()
    {
        await Button1.ClickAsync();
    }

    public async Task FocusButton1Async()
    {
        await Button1.FocusAsync();
    }

    public void Button1Blured()
    {
        Console.WriteLine("Button1 blurred!");
    }

    public void Button1Focused()
    {
        Console.WriteLine("Button1 focused!");
    }

    public void Button1Invalid()
    {
        Console.WriteLine("Button1 invalid!");
    }

    public async Task BlurLinkButton1Async()
    {
        await LinkButton1.BlurAsync();
    }

    public async Task FocusLinkButton1Async()
    {
        await LinkButton1.FocusAsync();
    }

    public void LinkButton1Blured()
    {
        Console.WriteLine("LinkButton1 blurred!");
    }

    public void LinkButton1Focused()
    {
        Console.WriteLine("LinkButton1 focused!");
    }

    public void LinkButton1Invalid()
    {
        Console.WriteLine("LinkButton1 invalid!");
    }
}
